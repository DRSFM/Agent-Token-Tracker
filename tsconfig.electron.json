{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist-electron",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./src/types/*"]
    }
  },
  "include": ["electron"]
}
