{
  "name": "agent-token-tracker",
  "version": "1.1.6",
  "description": "本地 Agent Token 计数器 — 估算 Claude Code / Codex 等本地 CLI 工具的 token 消耗",
  "author": "Token Dashboard Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DRSFM/Agent-Token-Tracker.git"
  },
  "homepage": "https://github.com/DRSFM/Agent-Token-Tracker#readme",
  "bugs": {
    "url": "https://github.com/DRSFM/Agent-Token-Tracker/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "token-tracker",
    "electron",
    "agent",
    "cli"
  ],
  "main": "dist-electron/main.js",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "bin": {
    "agent-token-tracker": "bin/agent-token-tracker.js"
  },
  "files": [
    "bin/",
    "dist/",
    "dist-electron/main.js",
    "dist-electron/preload.js",
    "assets/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "tsc -b && vite build && electron-builder",
    "release:portable": "npm run build && electron-builder --win dir --publish never && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "release:installer": "npm run build && electron-builder --win nsis --publish never",
    "release:mac": "npm run build && electron-builder --mac dmg --publish never",
    "release:friend": "npm run release:installer && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-installer-with-backgrounds.ps1",
    "package:npm": "npm run build && npm pack",
    "lint": "tsc --noEmit",
    "test:backend": "tsx --test tests/backend/*.test.ts"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "local.agent-token-tracker",
    "productName": "Agent Token Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/ssh.readme",
        "to": "ssh.readme"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "Agent-Token-Tracker-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Agent Token Tracker",
      "runAfterFinish": true,
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DRSFM",
        "repo": "Agent-Token-Tracker"
      }
    ],
    "mac": {
      "target": "dmg",
      "artifactName": "Agent-Token-Tracker-${version}-mac-${arch}.${ext}",
      "icon": "assets/app-icon.png"
    }
  }
}
